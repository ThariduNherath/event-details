generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  role      String   @default("attendee")
  createdAt DateTime @default(now())
  orders    Order[]
}

model TicketTier {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  priceCents  Int
  available   Int
  total       Int
  createdAt   DateTime @default(now())
  orders      Order[]
}

model Order {
  id          String   @id @default(cuid())
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  tier        TicketTier @relation(fields: [tierId], references: [id])
  tierId      String
  qty         Int
  amountCents Int
  createdAt   DateTime @default(now())
  status      String   @default("completed")
}

model Review {
  id        String   @id @default(cuid())
  name      String
  role      String?
  rating    Int
  text      String
  createdAt DateTime @default(now())
}

model AttendeeLiveStat {
  id        Int     @id @default(1)
  count     Int     @default(0)
  updatedAt DateTime @updatedAt
}
